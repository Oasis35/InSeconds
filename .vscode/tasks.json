{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "E2E: Run tests",
      "type": "shell",
      "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/run-e2e.ps1",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "clear": true
      },
      "problemMatcher": []
    }
  ]
}
